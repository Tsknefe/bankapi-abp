{
  "App": {
    "SelfUrl": "https://localhost:44389",
    "CorsOrigins": "https://localhost:44389,https://*.BankApiAbp.com",
    "RedirectAllowedUrls": ""
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5434;Database=bankdb;Username=bankuser;Password=bankpass"
  },
  "AuthServer": {
    "Authority": "https://localhost:44389",
    "RequireHttpsMetadata": false,
    "SwaggerClientId": "BankApiAbp_Swagger"
  },
  "StringEncryption": {
    "DefaultPassPhrase": "NDa6g77AeFycnY5Z"
  },

  "Redis": {
    "Configuration": "localhost:6379"
  },

  "RateLimiting": {
    "Global": {
      "PermitLimit": 120,
      "WindowSeconds": 60
    },
    "TransferPolicy": {
      "TokenLimit": 10,
      "TokensPerPeriod": 10,
      "PeriodSeconds": 60
    }
  },

  "OpenTelemetry": {
    "ServiceName": "BankApiAbp.HttpApi.Host",
    "OtlpEndpoint": "http://localhost:4317"
  },

  "Elastic": {
    "Uri": "http://localhost:9200",
    "IndexFormat": "bankapiabp-logs-{0:yyyy.MM.dd}"
  }
}